# N8N Configuration
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
NODE_ENV=production

# AI Hub Configuration
AIHUB_API_KEY=your-api-key-here
AIHUB_BASE_URL=https://hnd1.aihub.zeabur.ai/
AI_MODEL=claude-3-5-sonnet

# Database Configuration (PostgreSQL)
MEMORY_DB_HOST=your-postgres-host
MEMORY_DB_PORT=5432
MEMORY_DB_NAME=n8n_memory
MEMORY_DB_USER=postgres
MEMORY_DB_PASSWORD=your-password

# Telegram Integration
TELEGRAM_BOT_TOKEN=your-telegram-token
TELEGRAM_CHAT_ID=your-chat-id

# Google Calendar Integration
GOOGLE_CALENDAR_CREDENTIALS=your-credentials-json
